unit EventDetailsUnit;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.ExtCtrls, Vcl.ComCtrls;

type
  TForm3 = class(TForm)
    PanelDate: TPanel;
    PanelInfo: TPanel;
    MemoInfo: TRichEdit;
    procedure MemoInfoMouseLeave(Sender: TObject);
  private
    { Private declarations }
  public
    procedure ShowDetails(const AData: string);
  end;

var
  Form3: TForm3;

implementation

{$R *.dfm}


function CategoryColor(const Category: string): TColor;
begin
  if Category = 'Work' then
    Result := clBlue
  else if Category = 'Private' then
    Result := clGreen
  else if Category = 'Holiday' then
    Result := clRed
  else
    Result := clWindowText;   // no category = normal text
end;

procedure TForm3.ShowDetails(const AData: string);
const
  PadW = 16;    // horizontal padding inside the memo
  PadH = 12;    // vertical padding
  MinW = 140;   // popup never narrower than this
  MaxW = 480;   // ...nor wider (longer lines wrap)
  MinH = 40;
  MaxH = 420;   // ...nor taller (taller content scrolls)
var
  Lines, Disp: TStringList;
  I, P: Integer;
  Cat, Txt: string;
  Bmp: TBitmap;
  LineW, MaxLineW, AvailW, LineH, TotalLines, TextH: Integer;
  ChromeW, ChromeH: Integer;
begin
  MemoInfo.Lines.BeginUpdate;
  try
    MemoInfo.Clear;
    Lines := TStringList.Create;
    Disp  := TStringList.Create;
    try
      Lines.Text := AData;
      for I := 0 to Lines.Count - 1 do
      begin
        P := Pos(#1, Lines[I]);
        if P > 0 then
        begin
          Cat := Copy(Lines[I], 1, P - 1);
          Txt := Copy(Lines[I], P + 1, MaxInt);
        end
        else
        begin
          Cat := '';
          Txt := Lines[I];
        end;
        Disp.Add(Txt);   // keep the visible text so we can measure it

        MemoInfo.SelStart := MemoInfo.GetTextLen;
        MemoInfo.SelAttributes.Color := CategoryColor(Cat);
        MemoInfo.SelText := Txt + #13#10;
      end;

      // ---- measure with the RichEdit's own font ----
      Bmp := TBitmap.Create;
      try
        Bmp.Canvas.Font.Assign(MemoInfo.Font);
        LineH := Bmp.Canvas.TextHeight('Wg');
        if LineH < 1 then LineH := 16;

        MaxLineW := 0;
        for I := 0 to Disp.Count - 1 do
        begin
          LineW := Bmp.Canvas.TextWidth(Disp[I]);
          if LineW > MaxLineW then MaxLineW := LineW;
        end;

        TextH := MaxLineW + PadW;              // (reuse TextH as target width)
        if TextH < MinW then TextH := MinW;
        if TextH > MaxW then TextH := MaxW;
        MaxLineW := TextH;                     // MaxLineW now = clamped target width

        // count visual lines after wrapping to that width
        AvailW := MaxLineW - PadW;
        if AvailW < 1 then AvailW := 1;
        TotalLines := 0;
        for I := 0 to Disp.Count - 1 do
        begin
          LineW := Bmp.Canvas.TextWidth(Disp[I]);
          if LineW <= AvailW then
            Inc(TotalLines)
          else
            Inc(TotalLines, (LineW div AvailW) + 1);
        end;
        if TotalLines < 1 then TotalLines := 1;

        TextH := TotalLines * LineH + PadH;
        if TextH < MinH then TextH := MinH;
        if TextH > MaxH then TextH := MaxH;
      finally
        Bmp.Free;
      end;

      // ---- resize the form around the memo ----
      // Chrome = whatever surrounds the memo (borders, PanelDate, margins).
      ChromeW := ClientWidth  - MemoInfo.Width;
      ChromeH := ClientHeight - MemoInfo.Height;
      ClientWidth  := MaxLineW + ChromeW;
      ClientHeight := TextH    + ChromeH;
    finally
      Disp.Free;
      Lines.Free;
    end;
  finally
    MemoInfo.Lines.EndUpdate;
  end;
end;


procedure TForm3.MemoInfoMouseLeave(Sender: TObject);
var
  Pt: TPoint;
begin
  Pt := ScreenToClient(Mouse.CursorPos);
  // Only hide if the mouse actually left the entire form
  if not PtInRect(ClientRect, Pt) then
    Hide;
end;

end.
